# ============================================================
# Polymarket Positioner — Configuration
# Copy to .env and fill in your values
# ============================================================

# ── Wallet / Auth ────────────────────────────────────────────
# Your Polymarket private key (from browser export or wallet)
PRIVATE_KEY=

# Your proxy wallet address (the one that shows up on Polymarket)
PROXY_ADDRESS=

# Chain ID: 137 = Polygon mainnet
CHAIN_ID=137

# Signature type: 1 = email/magic link, 2 = browser wallet (MetaMask)
SIGNATURE_TYPE=1

# ── Target Assets ────────────────────────────────────────────
# Which 15-minute markets to trade (comma-separated)
TARGET_ASSETS=BTC,ETH,SOL

# Market interval in minutes (15 = 15-minute markets only)
MARKET_INTERVAL=15

# ── Strategy ─────────────────────────────────────────────────
# momentum  = directional bet using RSI+MACD price signals
# arbitrage = buy both UP+DOWN when combined price < ARB_MAX_COMBINED
# both      = run both simultaneously
STRATEGY=both

# RSI thresholds for momentum signals
RSI_OVERBOUGHT=60.0
RSI_OVERSOLD=40.0
RSI_PERIOD=14

# MACD settings
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# Minimum combined signal strength to enter (0.0–1.0)
# Lower = more trades but lower confidence
MIN_SIGNAL_STRENGTH=0.6

# Only enter momentum trades within N seconds of market open
ENTRY_WINDOW_SEC=120

# Arbitrage: buy both sides when UP+DOWN sum < this value
# Expected profit = 1.0 - combined (minus ~1% Polymarket fees)
ARB_MAX_COMBINED=0.98

# ── Trade Sizing / Risk ──────────────────────────────────────
# Base USDC per trade (scaled by signal strength)
TRADE_SIZE_USDC=10.0

# Hard cap per trade
MAX_TRADE_SIZE_USDC=50.0

# Minimum trade size (Polymarket minimum is ~$2)
MIN_TRADE_SIZE_USDC=2.0

# Maximum USDC exposure per single market
MAX_POSITION_PER_MARKET=100.0

# Maximum total USDC exposure across all open positions
MAX_TOTAL_EXPOSURE=300.0

# Slippage tolerance (0.03 = 3%)
SLIPPAGE_TOLERANCE=0.03

# ── Price Feed ───────────────────────────────────────────────
# Seconds between Binance price polls
PRICE_POLL_INTERVAL=5

# Number of 1-minute candles to keep in memory for TA
PRICE_HISTORY_BARS=50

# ── Polling ──────────────────────────────────────────────────
# Seconds between strategy evaluation cycles
MARKET_POLL_INTERVAL=10

# Seconds between full Polymarket market list refreshes
MARKET_REFRESH_INTERVAL=300

# ── Database ─────────────────────────────────────────────────
DB_PATH=positioner.db

# ── Mode ─────────────────────────────────────────────────────
# IMPORTANT: Set to false only when ready for real trading
DRY_RUN=true

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
